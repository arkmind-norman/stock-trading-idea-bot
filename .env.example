# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key (for LLM idea classification + extraction)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=...

# Postgres connection string.
# Local:    postgresql+asyncpg://user:password@localhost:5432/stockbot
# Railway:  set to the DATABASE_URL from the Railway Postgres plugin —
#           the app auto-converts postgres:// or postgresql:// to postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/stockbot

# ── Telegram mode ─────────────────────────────────────────────────────────────
# "polling"  — local dev (no public URL needed)
# "webhook"  — production on Railway (faster, no polling loop)
TELEGRAM_MODE=polling

# Required when TELEGRAM_MODE=webhook.
# Set to the public Railway URL of this service (no trailing slash).
# The app registers the webhook automatically on startup.
# WEBHOOK_URL=https://your-app.railway.app

# ── Optional tuning ───────────────────────────────────────────────────────────

# Fixed notional per simulated position (USD)
POSITION_NOTIONAL=1000

# Default holding period in trading days when no target/stop is given
DEFAULT_HOLDING_TRADING_DAYS=90

# Max concurrent open positions per user
MAX_OPEN_POSITIONS_PER_USER=10
