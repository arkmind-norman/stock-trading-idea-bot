# Anthropic API (for LLM idea classification + extraction)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=...

# Postgres connection string
# Local:   postgresql+asyncpg://user:password@localhost:5432/stockbot
# Railway: postgresql+asyncpg://...
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/stockbot

# Set to "webhook" in production, "polling" for local dev
TELEGRAM_MODE=polling

# Public URL for the webhook (production only — must be HTTPS)
# WEBHOOK_URL=https://your-app.railway.app

# Alpha Vantage API key (optional — yfinance is used by default)
# ALPHA_VANTAGE_API_KEY=...

# Fixed notional per simulated position (USD)
POSITION_NOTIONAL=1000

# Default holding period in trading days when no target/stop given
DEFAULT_HOLDING_DAYS=10
